# --- 域名和 Cloudflare 配置 ---
# 将 your.domain.com 替换为你的真实域名
YOUR_DOMAIN=your.domain.com
# 前往 Cloudflare -> My Profile -> API Tokens 创建一个拥有 Zone:DNS:Edit 权限的Token
CLOUDFLARE_API_TOKEN=你的Cloudflare_API_Token
# 您的邮箱，用于 Let's Encrypt 证书申请
ACME_EMAIL=your-email@example.com

# --- Nextcloud 管理员账户 ---
NEXTCLOUD_ADMIN_USER=admin
# 请使用一个非常安全的密码
NEXTCLOUD_ADMIN_PASSWORD=a_very_strong_password_for_nextcloud

# --- PostgreSQL 数据库配置 ---
POSTGRES_DB=nextcloud
POSTGRES_USER=nextcloud
# 请使用一个非常安全的密码
POSTGRES_PASSWORD=a_very_strong_password_for_postgres